#!/usr/bin/make -f
%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
	    -DCMAKE_INSTALL_PREFIX=/usr \
	    -DQCNPU_PERF_BUILD_CLI=OFF \
	    -DQCNPU_PERF_BUILD_DAEMON=ON \
	    -DFASTRPC_INCLUDE_DIR=/usr/include \
	    -DFASTRPC_LIBRARY=/usr/lib/aarch64-linux-gnu/libcdsprpc.so
